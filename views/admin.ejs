<%- include('partials/head') %>

<div class="admin-shell">

  <aside class="admin-aside">
    <a href="/" style="text-decoration:none;color:inherit;display:flex;align-items:baseline;gap:8px;font-family:'Cormorant Garamond','Noto Serif SC',serif;font-weight:600;font-size:18px">Alan<span style="color:var(--color-accent)">.</span><span style="font-family:'Lora','Noto Serif SC',serif;font-size:9px;letter-spacing:0.16em;text-transform:uppercase;color:var(--color-neutral-600)">Admin</span></a>
    <nav style="display:flex;flex-direction:column;gap:4px">
      <button type="button" class="admin-navbtn on" data-admin-tab="dash">数据看板 <small>ANALYTICS</small></button>
      <button type="button" class="admin-navbtn" data-admin-tab="content">内容管理 <small>CONTENT</small></button>
      <button type="button" class="admin-navbtn" data-admin-tab="users">用户管理 <small>USERS</small></button>
    </nav>
    <div style="margin-top:auto;display:flex;flex-direction:column;gap:9px;font-size:12px;color:var(--color-neutral-600)">
      <a href="/" style="color:inherit">← 返回前台</a>
      <span><%= user.email %></span>
      <a href="#" id="nav-logout" style="color:inherit">退出登录</a>
    </div>
  </aside>

  <main style="padding:36px clamp(24px,4vw,56px);max-width:1100px;box-sizing:border-box">

    <!-- ═══════════ 数据看板 ═══════════ -->
    <div id="tab-dash">
      <div style="display:flex;align-items:baseline;justify-content:space-between;gap:20px;flex-wrap:wrap">
        <h1 style="font-weight:400;font-size:34px;margin:0">数据看板</h1>
        <div class="seg">
          <label class="seg-opt"><input type="radio" name="range" value="7" <%= range === '7' ? 'checked' : '' %>>7 天</label>
          <label class="seg-opt"><input type="radio" name="range" value="30" <%= range === '30' ? 'checked' : '' %>>30 天</label>
          <label class="seg-opt"><input type="radio" name="range" value="all" <%= range === 'all' ? 'checked' : '' %>>全部</label>
        </div>
      </div>

      <div class="grid-cards4" style="margin-top:28px">
        <div class="card" style="padding:20px"><span class="card-kicker">页面访问 · PV</span><span class="tnum" style="font-family:'Cormorant Garamond',serif;font-size:34px"><%= fmtNum(dash.pv) %></span><span class="card-meta"><%= dash.pvDelta %></span></div>
        <div class="card" style="padding:20px"><span class="card-kicker">独立访客 · UV</span><span class="tnum" style="font-family:'Cormorant Garamond',serif;font-size:34px"><%= fmtNum(dash.uv) %></span><span class="card-meta"><%= dash.uvDelta %></span></div>
        <div class="card" style="padding:20px"><span class="card-kicker">工具使用次数</span><span class="tnum" style="font-family:'Cormorant Garamond',serif;font-size:34px;color:var(--color-accent)"><%= fmtNum(dash.toolUse) %></span><span class="card-meta"><%= dash.toolDelta %></span></div>
        <div class="card" style="padding:20px"><span class="card-kicker">注册用户</span><span class="tnum" style="font-family:'Cormorant Garamond',serif;font-size:34px"><%= fmtNum(dash.usersTotal) %></span><span class="card-meta">本月新增 <%= fmtNum(dash.usersMonth) %></span></div>
      </div>

      <div class="card" style="padding:28px;margin-top:20px">
        <div style="display:flex;justify-content:space-between;align-items:baseline"><span class="card-kicker">访问趋势 · Traffic</span><span class="card-meta tnum"><%= dash.trend.length ? dash.trend[0].d.slice(5).replace('-', '.') + ' – ' + dash.trend[dash.trend.length - 1].d.slice(5).replace('-', '.') : '' %></span></div>
        <svg viewBox="0 0 720 180" style="width:100%;height:auto;margin-top:14px" role="img" aria-label="访问趋势折线图">
          <line x1="0" y1="45" x2="720" y2="45" stroke="var(--color-divider)" stroke-width="1"></line>
          <line x1="0" y1="90" x2="720" y2="90" stroke="var(--color-divider)" stroke-width="1"></line>
          <line x1="0" y1="135" x2="720" y2="135" stroke="var(--color-divider)" stroke-width="1"></line>
          <line x1="0" y1="179" x2="720" y2="179" stroke="var(--color-neutral-400)" stroke-width="1"></line>
          <polyline fill="none" stroke="var(--color-neutral-400)" stroke-width="1.5" points="<%= uvPoints %>"></polyline>
          <polyline fill="none" stroke="var(--color-accent)" stroke-width="2" points="<%= pvPoints %>"></polyline>
          <% const lastPt = pvPoints.split(' ').pop().split(','); %>
          <circle cx="<%= lastPt[0] %>" cy="<%= lastPt[1] %>" r="3.5" fill="var(--color-accent)"></circle>
        </svg>
        <div style="display:flex;gap:20px;font-size:12px;color:var(--color-neutral-600);margin-top:9px">
          <span style="display:flex;align-items:center;gap:6px"><span style="width:16px;height:2px;background:var(--color-accent);display:inline-block"></span>页面访问 PV</span>
          <span style="display:flex;align-items:center;gap:6px"><span style="width:16px;height:1.5px;background:var(--color-neutral-400);display:inline-block"></span>独立访客 UV</span>
        </div>
      </div>

      <div class="grid-cards2" style="gap:20px;margin-top:20px">
        <div class="card" style="padding:28px">
          <span class="card-kicker">流量来源 · Sources</span>
          <div style="display:flex;flex-direction:column;gap:13.8px;margin-top:9.2px;font-size:13.5px">
            <% for (const s of dash.sources) { %>
            <div class="bar-row"><span><%= s.label %></span><div style="height:6px;border:1px solid var(--color-divider)"><div style="height:100%;width:<%= s.pct %>%;background:var(--color-accent-300)"></div></div><span class="tnum" style="text-align:right"><%= s.pct %>%</span></div>
            <% } %>
          </div>
        </div>
        <div class="card" style="padding:28px">
          <span class="card-kicker">工具使用排行 · Tool usage</span>
          <% if (dash.toolRank.length === 0) { %>
          <p style="font-size:13px;color:var(--color-neutral-600);margin:14px 0 0">暂无工具使用记录。</p>
          <% } else { %>
          <table class="table" style="margin-top:9.2px">
            <thead><tr><th>工具</th><th style="text-align:right">使用次数</th></tr></thead>
            <tbody>
              <% for (const t of dash.toolRank) { %>
              <tr><td><%= t.name %></td><td class="tnum" style="text-align:right"><%= fmtNum(t.n) %></td></tr>
              <% } %>
            </tbody>
          </table>
          <% } %>
        </div>
      </div>

      <div class="card" style="padding:28px;margin-top:20px">
        <div style="display:flex;justify-content:space-between;align-items:baseline"><span class="card-kicker">注册转化漏斗 · Funnel</span><span class="card-meta"><%= range === 'all' ? '全部时间' : '近 ' + range + ' 天' %></span></div>
        <div style="display:flex;flex-direction:column;gap:13.8px;margin-top:14px;font-size:13.5px">
          <% dash.funnel.forEach(function (f, i) { %>
          <div class="funnel-row"><span><%= f.label %></span><div style="height:22px;border:1px solid var(--color-divider)"><div style="height:100%;width:<%= f.pct %>%;background:<%= i < 2 ? 'var(--color-accent-100)' : (i < 4 ? 'var(--color-accent-300)' : 'var(--color-accent)') %>"></div></div><span class="tnum" style="text-align:right"><%= fmtNum(f.n) %> · <%= f.pct %>%</span></div>
          <% }); %>
        </div>
      </div>

      <div class="card" style="padding:28px;margin-top:20px">
        <span class="card-kicker">文章阅读 Top 5 · Reads</span>
        <table class="table" style="margin-top:9.2px">
          <thead><tr><th>文章</th><th>发布日期</th><th style="text-align:right">阅读</th><th style="text-align:right">完读率</th></tr></thead>
          <tbody>
            <% for (const p of dash.topPosts) { %>
            <tr><td><%= p.title %></td><td class="tnum"><%= fmtDate(p.published_at) %></td><td class="tnum" style="text-align:right"><%= fmtNum(p.views) %></td><td class="tnum" style="text-align:right"><%= p.completion %>%</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ═══════════ 内容管理 ═══════════ -->
    <div id="tab-content" hidden>
      <div style="display:flex;align-items:baseline;justify-content:space-between;gap:20px;flex-wrap:wrap">
        <h1 style="font-weight:400;font-size:34px;margin:0">内容管理</h1>
        <button type="button" class="btn btn-primary" id="btn-new-content">+ 新建内容</button>
      </div>
      <div style="display:flex;gap:9.2px;margin-top:20px">
        <button type="button" class="tag tag-outline" data-content-filter="all" style="cursor:pointer;background:transparent">全部</button>
        <button type="button" class="tag tag-neutral" data-content-filter="post" style="cursor:pointer">文章</button>
        <button type="button" class="tag tag-neutral" data-content-filter="course" style="cursor:pointer">课程</button>
        <button type="button" class="tag tag-neutral" data-content-filter="tool" style="cursor:pointer">工具</button>
      </div>
      <div class="card" style="padding:28px;margin-top:20px">
        <table class="table">
          <thead><tr><th>标题</th><th>类型</th><th>状态</th><th>更新时间</th><th style="text-align:right">操作</th></tr></thead>
          <tbody id="content-rows">
            <% for (const p of posts) { %>
            <tr data-ctype="post">
              <td><%= p.title %></td><td>文章</td>
              <td><span class="tag <%= p.status === 'published' ? 'tag-accent' : 'tag-neutral' %>"><%= p.status === 'published' ? '已发布' : '草稿' %></span></td>
              <td class="tnum"><%= fmtDate(p.published_at || p.updated_at) %></td>
              <td style="text-align:right"><button type="button" class="btn btn-ghost" data-edit="post" data-id="<%= p.id %>">编辑</button></td>
            </tr>
            <% } %>
            <% for (const c of courses) { %>
            <tr data-ctype="course">
              <td><%= c.title %></td><td>课程</td>
              <td><span class="tag <%= c.status === 'live' ? 'tag-accent' : 'tag-neutral' %>"><%= c.status === 'live' ? '已发布' : '筹备中' %></span></td>
              <td class="tnum"><%= fmtDate(c.updated_at) %></td>
              <td style="text-align:right"><button type="button" class="btn btn-ghost" data-edit="course" data-id="<%= c.id %>">编辑</button></td>
            </tr>
            <% } %>
            <% for (const t of tools) { %>
            <tr data-ctype="tool">
              <td><%= t.name %></td><td>工具</td>
              <td><span class="tag <%= t.status === 'live' ? 'tag-accent' : 'tag-neutral' %>"><%= t.status === 'live' ? '已发布' : '筹备中' %></span></td>
              <td class="tnum"><%= fmtDate(t.updated_at) %></td>
              <td style="text-align:right"><button type="button" class="btn btn-ghost" data-edit="tool" data-id="<%= t.id %>">编辑</button></td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <div class="card" style="padding:28px;margin-top:20px">
        <div style="display:flex;justify-content:space-between;align-items:baseline;gap:20px;flex-wrap:wrap">
          <span class="card-kicker">Agent 自动化 · 小龙虾 / Hermes</span>
          <span style="font-size:12px;color:var(--color-neutral-600)"><%= agentStatus.mode %><%= agentStatus.lastActive ? ' · 最近活动 ' + fmtDate(agentStatus.lastActive) : '' %></span>
        </div>
        <div style="display:flex;flex-direction:column;margin-top:9.2px">
          <div style="display:grid;grid-template-columns:minmax(0,2fr) minmax(0,3fr) auto;gap:20px;align-items:baseline;padding:13.8px 0;border-bottom:1px solid var(--color-divider)">
            <span style="font-size:14px">文章草稿生成</span>
            <span style="font-size:13px;color:var(--color-neutral-600)">小龙虾 CLI · 生成草稿进入「草稿」状态，人工审核后发布</span>
            <span class="tag tag-neutral">预留接口</span>
          </div>
          <div style="display:grid;grid-template-columns:minmax(0,2fr) minmax(0,3fr) auto;gap:20px;align-items:baseline;padding:13.8px 0;border-bottom:1px solid var(--color-divider)">
            <span style="font-size:14px">评论检测与自动回复</span>
            <span style="font-size:13px;color:var(--color-neutral-600)">常见问题即时回复并标注，其余转人工 · 点击右侧开关切换</span>
            <button type="button" class="tag <%= agentStatus.autoreply ? 'tag-accent' : 'tag-neutral' %>" id="agent-toggle" data-on="<%= agentStatus.autoreply ? '1' : '0' %>" style="cursor:pointer"><%= agentStatus.autoreply ? '已开启' : '已关闭' %></button>
          </div>
          <div style="display:grid;grid-template-columns:minmax(0,2fr) minmax(0,3fr) auto;gap:20px;align-items:baseline;padding:13.8px 0">
            <span style="font-size:14px">AI 诊断报告生成</span>
            <span style="font-size:13px;color:var(--color-neutral-600)">Hermes Agent · 问卷提交后自动生成诊断报告<%= mailerEnabled ? '并邮件送达' : '（邮件通道未配置，报告入库可查）' %></span>
            <span class="tag <%= llmEnabled ? 'tag-accent' : 'tag-outline' %>"><%= llmEnabled ? '已连接 LLM' : '模板模式' %></span>
          </div>
        </div>
      </div>
      <p style="font-size:12px;color:var(--color-neutral-600);margin-top:14px">前台各页面的文章、课程与工具内容均从此处维护；发布后前台即时更新。LLM / 邮件通道在服务器 .env 中配置。</p>
    </div>

    <!-- ═══════════ 用户管理 ═══════════ -->
    <div id="tab-users" hidden>
      <div style="display:flex;align-items:baseline;justify-content:space-between;gap:20px;flex-wrap:wrap">
        <h1 style="font-weight:400;font-size:34px;margin:0">用户管理</h1>
        <input class="input" type="search" id="user-search" placeholder="搜索用户 / Search" style="max-width:240px">
      </div>
      <div class="grid-cards3" style="gap:20px;margin-top:28px">
        <div class="card" style="padding:20px"><span class="card-kicker">注册用户</span><span class="tnum" style="font-family:'Cormorant Garamond',serif;font-size:34px"><%= fmtNum(dash.usersTotal) %></span></div>
        <div class="card" style="padding:20px"><span class="card-kicker">本月新增</span><span class="tnum" style="font-family:'Cormorant Garamond',serif;font-size:34px;color:var(--color-accent)"><%= fmtNum(dash.usersMonth) %></span></div>
        <div class="card" style="padding:20px"><span class="card-kicker">诊断提交</span><span class="tnum" style="font-family:'Cormorant Garamond',serif;font-size:34px"><%= fmtNum(counts.submissions) %></span></div>
      </div>
      <div class="card" style="padding:28px;margin-top:20px">
        <table class="table">
          <thead><tr><th>用户</th><th>角色</th><th>注册时间</th><th>来源</th><th>工具使用</th></tr></thead>
          <tbody id="user-rows">
            <% for (const u of users) { %>
            <tr><td><%= u.name %> · <%= u.email %></td><td><%= u.role === 'admin' ? '管理员' : '会员' %></td><td class="tnum"><%= fmtDate(u.created_at) %></td><td><%= u.source %></td><td class="tnum"><%= u.tool_uses %> 次</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <div class="card" style="padding:28px;margin-top:20px">
        <div style="display:flex;justify-content:space-between;align-items:baseline"><span class="card-kicker">诊断提交记录 · Diagnosis</span><span class="card-meta">最近 20 条 · 共 <%= fmtNum(counts.submissions) %> 条</span></div>
        <% if (submissions.length === 0) { %>
        <p style="font-size:13px;color:var(--color-neutral-600);margin:14px 0 0">暂无诊断提交。</p>
        <% } else { %>
        <table class="table" style="margin-top:9.2px">
          <thead><tr><th>企业</th><th>邮箱</th><th>评级</th><th style="text-align:right">结合点</th><th>生成方式</th><th>报告邮件</th><th>时间</th></tr></thead>
          <tbody>
            <% for (const s of submissions) { %>
            <tr><td><%= s.company %></td><td><%= s.email %></td><td class="tnum"><%= s.level %> / L5</td><td class="tnum" style="text-align:right"><%= s.spots %></td><td><%= s.generator === 'llm' ? 'LLM' : '模板' %></td><td><%= s.emailed ? '已发送' : '未发送' %></td><td class="tnum"><%= fmtDate(s.created_at) %></td></tr>
            <% } %>
          </tbody>
        </table>
        <% } %>
      </div>

      <div class="card" style="padding:28px;margin-top:20px">
        <div style="display:flex;justify-content:space-between;align-items:baseline"><span class="card-kicker">站内留言 · Messages</span><span class="card-meta">最近 10 条 · 共 <%= fmtNum(counts.messages) %> 条 · 订阅 <%= fmtNum(counts.subscribers) %> 人</span></div>
        <% if (messages.length === 0) { %>
        <p style="font-size:13px;color:var(--color-neutral-600);margin:14px 0 0">暂无留言。</p>
        <% } else { %>
        <div style="display:flex;flex-direction:column;margin-top:9.2px">
          <% for (const m of messages) { %>
          <div style="padding:13.8px 0;border-bottom:1px solid var(--color-divider)">
            <div style="display:flex;gap:13.8px;align-items:baseline;font-size:13px;flex-wrap:wrap"><span style="font-size:14px"><%= m.name || '（未署名）' %></span><span style="color:var(--color-neutral-600)"><%= m.email %></span><span class="tnum" style="color:var(--color-neutral-600)"><%= fmtDate(m.created_at) %></span></div>
            <p style="font-size:13.5px;line-height:24px;margin:6px 0 0;color:color-mix(in srgb, var(--color-text) 80%, transparent)"><%= m.body %></p>
          </div>
          <% } %>
        </div>
        <% } %>
      </div>
    </div>

  </main>
</div>

<!-- 编辑对话框 -->
<div class="dialog-backdrop" id="edit-backdrop" hidden style="z-index:90">
  <div class="dialog" style="width:min(640px,100%);max-height:88vh;overflow-y:auto">
    <span class="dialog-title" id="edit-title">编辑</span>
    <div class="dialog-body" id="edit-fields" style="display:flex;flex-direction:column;gap:14px"></div>
    <p class="form-error" id="edit-error"></p>
    <div class="dialog-actions">
      <button type="button" class="btn btn-secondary" id="edit-cancel">取消</button>
      <button type="button" class="btn btn-primary" id="edit-save">保存</button>
    </div>
  </div>
</div>

<script type="application/json" id="admin-data"><%- JSON.stringify({
  posts: posts.map(p => ({ id: p.id, title: p.title, category: p.category, excerpt: p.excerpt, content_md: p.content_md, read_minutes: p.read_minutes, status: p.status })),
  courses: courses.map(c => ({ id: c.id, title: c.title, description: c.description, lectures: c.lectures, price_yuan: c.price_cents == null ? '' : Math.round(c.price_cents / 100), status: c.status, tag: c.tag, kicker: c.kicker })),
  tools: tools.map(t => ({ id: t.id, name: t.name, description: t.description, status: t.status, url: t.url })),
}) %></script>
<script src="/js/admin.js" defer></script>
<script src="/js/assistant.js" defer></script>
</body>
</html>
