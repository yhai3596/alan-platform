      </div>
    </div>
    <div style="display:flex;gap:13.8px;margin-top:42px;flex-wrap:wrap">
      <a class="btn btn-primary" href="/diagnosis" style="text-decoration:none" data-track="cta_click" data-track-meta="services_diagnosis">开始 AI 诊断问卷 →</a>
      <a class="btn btn-ghost" href="/about" style="text-decoration:none">直接联系我</a>
